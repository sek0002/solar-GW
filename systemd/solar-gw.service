[Unit]
Description=solar-GW FastAPI dashboard
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/solar-gw
EnvironmentFile=/opt/solar-gw/.env
ExecStart=/opt/solar-gw/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8003
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
