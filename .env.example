APP_NAME=solar-GW
ENVIRONMENT=production
DASHBOARD_TITLE=Home Energy Control
REFRESH_INTERVAL_SECONDS=30
REQUEST_TIMEOUT_SECONDS=15
DEMO_MODE=true
APP_AUTH_SECRET=
APP_OTP_TOTP_SECRET=
APP_OTP_ISSUER=solar-GW
APP_SESSION_HOURS=12
APP_AUTH_COOKIE_NAME=solar_gw_session
APP_AUTH_COOKIE_SECURE=false
APP_AUTH_LOCKOUT_MINUTES=15
APP_AUTH_MAX_ATTEMPTS=5

# Tesla Fleet API
TESLA_API_BASE_URL=https://fleet-api.prd.na.vn.cloud.tesla.com
TESLA_AUTH_URL=https://auth.tesla.com/oauth2/v3/authorize
TESLA_TOKEN_URL=https://fleet-auth.prd.vn.cloud.tesla.com/oauth2/v3/token
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
TESLA_REDIRECT_URI=http://localhost:8003/auth/tesla/callback
TESLA_SCOPE=openid offline_access user_data vehicle_device_data vehicle_charging_cmds
TESLA_ACCESS_TOKEN=
TESLA_VEHICLE_VINS=
TESLA_TOKEN_STORE_PATH=.data/tesla_oauth.json
WALL_CONNECTOR_NAME=Wall Connector 3
WALL_CONNECTOR_LOCATION=Garage
WALL_CONNECTOR_MAX_KW=11
WALL_CONNECTOR_CIRCUIT_AMPS=32

# Growatt
# Use the vendor-issued or proxy URL that returns current site/device JSON for your installer account.
GROWATT_OVERVIEW_URL=
GROWATT_BATTERY_URL=
GROWATT_TOKEN=
GROWATT_SERVER_URL=https://openapi-au.growatt.com
GROWATT_PLATFORM=hybrid_inverter

# GoodWe
# Either use SEMS username/password + Plant ID, or use authorized endpoint(s) if GoodWe has enabled direct API access for your account.
GOODWE_OVERVIEW_URL=
GOODWE_BATTERY_URL=
GOODWE_TOKEN=
GOODWE_USERNAME=
GOODWE_PASSWORD=
GOODWE_PLANT_ID=
GOODWE_API_URL=https://semsportal.com/api/
